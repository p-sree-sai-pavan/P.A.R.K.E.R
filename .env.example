# ════════════════════════════════════════════════════════════════════════════════
# Parker AI - Environment Configuration
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DB_URI=postgresql://postgres:postgres@localhost:5442/postgres?sslmode=disable

# Connection retry (optional)
DB_MAX_RETRIES=3
DB_RETRY_DELAY=2.0

# ── LLM API Keys ───────────────────────────────────────────────────────────────
# Required for Groq provider
GROQ_API_KEY=your_groq_api_key_here

# ── Chat LLM (High Quality Responses) ─────────────────────────────────────────
CHAT_LLM_PROVIDER=groq
CHAT_LLM_MODEL=llama-3.3-70b-versatile
CHAT_LLM_TEMPERATURE=0.7
CHAT_LLM_MAX_TOKENS=1024
CHAT_LLM_TIMEOUT=60

# ── Memory LLM (Fast Local Extraction) ───────────────────────────────────────
# Requires Ollama running locally with the model installed
# Install: ollama pull qwen2.5:3b
MEMORY_LLM_PROVIDER=ollama
MEMORY_LLM_MODEL=qwen2.5:3b
MEMORY_LLM_TEMPERATURE=0
MEMORY_LLM_CTX=2048

# ── Embeddings ────────────────────────────────────────────────────────────────
# Requires Ollama running locally with the model installed
# Install: ollama pull mxbai-embed-large
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIMS=1024

# ── User (optional) ───────────────────────────────────────────────────────────
DEFAULT_USER_ID=u1
DEFAULT_THREAD_ID=thread_u1

# ── Reminders (optional) ──────────────────────────────────────────────────────
REMINDER_POLL_INTERVAL=30